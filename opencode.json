{
  "$schema": "https://opencode.ai/config.json",

  "model": "opencode/mimo-v2.5-free",
  "small_model": "openrouter/z-ai/glm-4.5-air:free",

  "agent": {
    "huitzilopochtli": {
      "model": "opencode/deepseek-v4-flash-free",
      "color": "#d3e22b",
      "temperature": 0.5,
      "compaction": {
        "auto": true,
        "prune": true,
        "reserved": 10000
      },
      "model_options": {
        "textVerbosity": "low",
        "reasoningSummary": "auto",
        "thinking": {
          "type": "enabled",
          "budgetTokens": 7000
        }
      }
    },
    "quetzalcoatl": {
      "model": "openrouter/deepseek/deepseek-v4-flash:free",
      "color": "#ffffff",
      "temperature": 0.2,
      "steps": 15,
      "compaction": {
        "auto": true,
        "prune": true,
        "reserved": 10000
      },
      "model_options": {
        "textVerbosity": "low",
        "reasoningSummary": "auto",
        "thinking": {
          "type": "enabled",
          "budgetTokens": 6000
        }
      }
    },
    "moctezuma": {
      "model": "opencode/big-pickle",
      "color": "#8B4513",
      "temperature": 0.3,
      "steps": 20,
      "compaction": {
        "auto": true,
        "prune": true,
        "reserved": 10000
      },
      "model_options": {
        "textVerbosity": "low",
        "reasoningSummary": "auto",
        "thinking": {
          "type": "enabled",
          "budgetTokens": 7000
        }
      }
    },
    "tlaloc": {
      "model": "opencode/deepseek-v4-flash-free",
      "color": "#0066cc",
      "temperature": 0.4,
      "compaction": {
        "auto": true,
        "prune": true,
        "reserved": 10000
      },
      "model_options": {
        "textVerbosity": "low",
        "reasoningSummary": "auto",
        "thinking": {
          "type": "enabled",
          "budgetTokens": 8000
        }
      }
    },
    "mictlantecuhtli": {
      "model": "opencode/deepseek-v4-flash-free",
      "color": "#2d2d2d",
      "temperature": 0.2,
      "compaction": {
        "auto": true,
        "prune": true,
        "reserved": 10000
      },
      "model_options": {
        "textVerbosity": "low",
        "reasoningSummary": "auto",
        "thinking": {
          "type": "enabled",
          "budgetTokens": 7000
        }
      }
    },
    "tezcatlipoca": {
      "model": "opencode/big-pickle",
      "color": "#ff3134",
      "temperature": 0.4,
      "compaction": {
        "auto": true,
        "prune": true,
        "reserved": 10000
      },
      "model_options": {
        "textVerbosity": "low",
        "reasoningSummary": "auto",
        "thinking": {
          "type": "enabled",
          "budgetTokens": 8000
        }
      }
    },
    "build": {
      "disable": true
    },
    "plan": {
      "disable": true
    },
    "explore": {
      "model": "openrouter/openrouter/free"
    },
    "general": {
      "disable": true
    }
  },

  "instructions": [
    "CONTRIBUTING.md",
    "WORKFLOW.md",
    "SPEC.md",
    "USER_GUIDE.md",
    "docs/opencode/08-orchestration-patterns.md"
  ],

  "permission": {
    "bash": {
      "*": "ask",
      "ls": "allow",
      "ls *": "allow",
      "grep *": "allow",
      "wc *": "allow",
      "find *": "allow",
      "echo": "allow",
      "echo *": "allow",
      "printf *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "sort *": "allow",
      "uniq *": "allow",
      "cut *": "allow",
      "awk *": "allow",
      "sed *": "allow",
      "tr *": "allow",
      "diff *": "allow",
      "tee *": "allow",
      "xargs *": "allow",
      "nl *": "allow",
      "column *": "allow",
      "cksum *": "allow",
      "env": "deny",
      "env *": "deny",
      "printenv *": "deny",
      "which *": "allow",
      "pwd": "allow",
      "file *": "allow",
      "stat *": "allow",
      "du *": "allow",
      "date *": "allow",
      "dirname *": "allow",
      "basename *": "allow",
      "realpath *": "allow",
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git branch": "allow",
      "git branch -r *": "allow",
      "git show *": "allow",
      "git bisect *": "allow",
      "git blame *": "allow",
      "* .env.example": "allow",
      "* .env": "deny",
      "* .env.*": "deny",
      "* ./.env": "deny",
      "* ./.env.*": "deny"
      
    },
    "read": {
      "*": "allow",
      "*.env.example": "allow",
      "*.env": "deny",
      "*.env.*": "deny"
    }
  },

  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "excel": {
      "type": "local",
      "command": ["uvx", "excel-mcp-server", "stdio"],
      "enabled": false
    },
    "jupyter": {
      "type": "local",
      "command": ["uvx", "mcp-jupyter-notebook"],
      "enabled": false,
      "env": {
        "MCP_JUPYTER_SESSION_MODE": "server",
        "MCP_JUPYTER_BASE_URL": "http://localhost:8888",
        "MCP_JUPYTER_TOKEN": "mcp-dev-token",
        "MCP_JUPYTER_NOTEBOOK_PATH": "agent_demo.ipynb"
      }
    }
  }
}
