{
  "$schema": "https://opencode.ai/config.json",

  "model": "opencode/deepseek-v4-flash-free",
  "small_model": "openrouter/z-ai/glm-4.5-air:free",

  "agent": {
    "build": {
      "model": "opencode/deepseek-v4-flash-free",
      "disable": true
    },
    "plan": {
      "model": "opencode/big-pickle",
      "disable": true
    },
    "platform-engineer": {
      "hidden": true
    },
    "explore": {
      "model": "opencode/nemotron-3-super-free"
    }
  },

  "instructions": [
    "CONTRIBUTING.md",
    "USER_GUIDE.md",
    "docs/opencode/08-orchestration-patterns.md"
  ],

  "permission": {
    "bash": {
      "*": "ask",
      "ls": "allow",
      "ls *": "allow",
      "grep *": "allow",
      "wc *": "allow",
      "find *": "allow",
      "echo": "allow",
      "echo *": "allow",
      "printf *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "sort *": "allow",
      "uniq *": "allow",
      "cut *": "allow",
      "awk *": "allow",
      "sed *": "allow",
      "tr *": "allow",
      "diff *": "allow",
      "tee *": "allow",
      "xargs *": "allow",
      "nl *": "allow",
      "column *": "allow",
      "cksum *": "allow",
      "env": "deny",
      "env *": "deny",
      "printenv *": "deny",
      "which *": "allow",
      "pwd": "allow",
      "file *": "allow",
      "stat *": "allow",
      "du *": "allow",
      "date *": "allow",
      "dirname *": "allow",
      "basename *": "allow",
      "realpath *": "allow",
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git branch *": "allow",
      "* .env": "deny",
      "* .env.*": "deny",
      "* ./.env": "deny",
      "* ./.env.*": "deny",
      "* .env.example": "allow"
    },
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    }
  },

  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    }
  }
}
