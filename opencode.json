{
  "$schema": "https://opencode.ai/config.json",

  "model": "openrouter/openrouter/free",
  "small_model": "openrouter/z-ai/glm-4.5-air:free",

  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },

  "provider": {
    "openai": {
      "models": {
        "gpt-5": {
          "options": {
            "reasoningEffort": "medium",
            "textVerbosity": "low",
            "reasoningSummary": "auto"
          },
          "variants": {
            "deep-think": {
              "reasoningEffort": "high",
              "textVerbosity": "low",
              "reasoningSummary": "auto"
            },
            "economy": {
              "reasoningEffort": "low",
              "textVerbosity": "low",
              "reasoningSummary": "none"
            }
          }
        },
        "gpt-5.5-pro": {
          "options": {
            "reasoningEffort": "high",
            "textVerbosity": "low",
            "reasoningSummary": "auto"
          },
          "variants": {
            "deep-think": {
              "reasoningEffort": "xhigh",
              "textVerbosity": "low"
            },
            "economy": {
              "reasoningEffort": "medium",
              "textVerbosity": "low",
              "reasoningSummary": "none"
            }
          }
        }
      }
    },
    "anthropic": {
      "models": {
        "claude-sonnet-4-6": {
          "options": {
            "thinking": {
              "type": "adaptive",
              "budgetTokens": 8000,
              "display": "summarized"
            }
          },
          "variants": {
            "deep-think": {
              "thinking": {
                "type": "enabled",
                "budgetTokens": 16000
              }
            },
            "economy": {
              "thinking": {
                "type": "adaptive",
                "budgetTokens": 4000,
                "display": "none"
              }
            }
          }
        },
        "claude-opus-4-6": {
          "options": {
            "thinking": {
              "type": "adaptive",
              "display": "summarized"
            }
          },
          "variants": {
            "deep-think": {
              "thinking": {
                "type": "enabled",
                "budgetTokens": 32000
              }
            },
            "economy": {
              "thinking": {
                "type": "adaptive",
                "display": "none"
              }
            }
          }
        },
        "claude-opus-4-7": {
          "options": {
            "thinking": {
              "type": "adaptive",
              "display": "summarized"
            }
          },
          "variants": {
            "deep-think": {
              "thinking": {
                "type": "enabled",
                "budgetTokens": 32000
              }
            },
            "economy": {
              "thinking": {
                "type": "adaptive",
                "display": "none"
              }
            }
          }
        },
        "claude-opus-4-8": {
          "options": {
            "thinking": {
              "type": "adaptive",
              "display": "summarized"
            }
          },
          "variants": {
            "deep-think": {
              "thinking": {
                "type": "enabled",
                "budgetTokens": 32000
              }
            },
            "economy": {
              "thinking": {
                "type": "adaptive",
                "display": "none"
              }
            }
          }
        }
      }
    },
    "google": {
      "models": {
        "gemini-3.1-pro": {
          "options": {
            "thinkingConfig": {
              "includeThoughts": false,
              "thinkingLevel": "medium"
            }
          },
          "variants": {
            "deep-think": {
              "thinkingConfig": {
                "includeThoughts": true,
                "thinkingLevel": "high"
              }
            },
            "economy": {
              "thinkingConfig": {
                "includeThoughts": false,
                "thinkingLevel": "low"
              }
            }
          }
        }
      }
    },
    "deepseek": {
      "models": {
        "deepseek-v4-pro": {
          "options": {
            "thinking": { "type": "enabled" },
            "reasoningEffort": "high"
          },
          "variants": {
            "deep-think": {
              "thinking": { "type": "enabled" },
              "reasoningEffort": "max"
            },
            "economy": {
              "thinking": { "type": "disabled" },
              "reasoningEffort": "low"
            }
          }
        },
        "deepseek-v4-flash": {
          "options": {
            "thinking": { "type": "enabled" },
            "reasoningEffort": "medium"
          },
          "variants": {
            "deep-think": {
              "thinking": { "type": "enabled" },
              "reasoningEffort": "high"
            },
            "economy": {
              "thinking": { "type": "disabled" },
              "reasoningEffort": "low"
            }
          }
        },
        "deepseek-r1": {
          "options": {
            "thinking": { "type": "enabled" },
            "reasoningEffort": "high"
          },
          "variants": {
            "deep-think": {
              "thinking": { "type": "enabled" },
              "reasoningEffort": "max"
            },
            "economy": { "reasoningEffort": "low" }
          }
        },
        "deepseek-v3.2": {
          "options": {
            "thinking": { "type": "enabled" },
            "reasoningEffort": "medium"
          },
          "variants": {
            "deep-think": {
              "thinking": { "type": "enabled" },
              "reasoningEffort": "high"
            },
            "economy": {
              "thinking": { "type": "disabled" },
              "reasoningEffort": "low"
            }
          }
        }
      }
    },
    "z-ai": {
      "models": {
        "glm-5": {
          "options": { "thinking": { "type": "enabled" } },
          "variants": {
            "economy": { "thinking": { "type": "disabled" } }
          }
        },
        "glm-5.1": {
          "options": { "thinking": { "type": "enabled" } },
          "variants": {
            "economy": { "thinking": { "type": "disabled" } }
          }
        },
        "glm-4.5": {
          "options": { "thinking": { "type": "disabled" } }
        },
        "glm-4.5-air": { "options": {} }
      }
    },
    "moonshot": {
      "models": {
        "kimi-k2.5": {
          "options": { "thinking": { "type": "enabled" } },
          "variants": {
            "economy": { "thinking": { "type": "disabled" } }
          }
        },
        "kimi-k2.6": {
          "options": { "thinking": { "type": "enabled" } },
          "variants": {
            "economy": { "thinking": { "type": "disabled" } }
          }
        }
      }
    },
    "openrouter": {
      "models": {
        "qwen/qwen3.6-plus": {
          "options": {
            "chat_template_kwargs": { "enable_thinking": true }
          }
        },
        "qwen/qwen3.5-plus": {
          "options": {
            "chat_template_kwargs": { "enable_thinking": true }
          }
        },
        "qwen/qwen3-coder": { "options": {} }
      }
    },
    "minimax": {
      "models": {
        "minimax-m2.7": { "options": { "temperature": 0.6 } },
        "minimax-m2.5": { "options": { "temperature": 0.6 } }
      }
    }
  },

  "agent": {
    "huitzilopochtli": {
      "model": "openrouter/openrouter/free",
      "color": "#d3e22b",
      "temperature": 0.5,
      "steps": 20
    },
    "quetzalcoatl": {
      "model": "opencode/big-pickle",
      "color": "#ffffff",
      "temperature": 0.3,
      "steps": 15
    },
    "moctezuma": {
      "model": "nvidia/openai/gpt-oss-120b",
      "color": "#8B4513",
      "temperature": 0.1
    },
    "tlaloc": {
      "model": "opencode/mimo-v2.5-free",
      "color": "#0066cc",
      "temperature": 0.2
    },
    "mictlantecuhtli": {
      "model": "opencode/mimo-v2.5-free",
      "color": "#2d2d2d",
      "temperature": 0.2
    },
    "tezcatlipoca": {
      "model": "opencode/big-pickle",
      "color": "#ff3134",
      "temperature": 0.1,
      "steps": 15
    },
    "build": {
      "disable": true
    },
    "plan": {
      "disable": true
    },
    "explore": {
      "model": "openrouter/openrouter/free"
    },
    "general": {
      "disable": true
    }
  },

  "instructions": [
    "CONTRIBUTING.md",
    "WORKFLOW.md",
    "SPEC.md",
    "CODE_STYLE.md",
    "tasks/*.md",
    "USER_GUIDE.md"
  ],

  "permission": {
    "task": {
      "*": "deny"
    },
    "bash": {
      "*": "ask",
      "cd *": "allow",
      "ls": "allow",
      "ls *": "allow",
      "tree *": "allow",
      "grep *": "allow",
      "wc *": "allow",
      "find *": "allow",
      "echo": "allow",
      "echo *": "allow",
      "printf *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "sort *": "allow",
      "uniq *": "allow",
      "cut *": "allow",
      "awk *": "allow",
      "sed *": "allow",
      "tr *": "allow",
      "diff *": "allow",
      "comm *": "allow",
      "paste *": "allow",
      "join *": "allow",
      "tee *": "allow",
      "xargs *": "allow",
      "nl *": "allow",
      "column *": "allow",
      "cksum *": "allow",
      "strings *": "allow",
      "jq *": "allow",
      "rg *": "allow",
      "ag *": "allow",
      "ack *": "allow",
      "fd *": "allow",
      "bat *": "allow",
      "exa *": "allow",
      "eza *": "allow",
      "delta *": "allow",
      "hexyl *": "allow",
      "df *": "allow",
      "free": "allow",
      "uname *": "allow",
      "whoami": "allow",
      "id": "allow",
      "uptime": "allow",
      "ps *": "allow",
      "lsof *": "allow",
      "dig *": "allow",
      "nslookup *": "allow",
      "host *": "allow",
      "curl *": "allow",
      "http *": "allow",
      "unzip -l *": "allow",
      "zipinfo *": "allow",
      "tar -tf *": "allow",
      "env": "deny",
      "env *": "deny",
      "printenv *": "deny",
      "which *": "allow",
      "pwd": "allow",
      "file *": "allow",
      "stat *": "allow",
      "du *": "allow",
      "date *": "allow",
      "dirname *": "allow",
      "basename *": "allow",
      "realpath *": "allow",
      "git status *": "allow",
      "git status": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git branch": "allow",
      "git branch -r *": "allow",
      "git branch -a": "allow",
      "git show *": "allow",
      "git bisect *": "allow",
      "git blame *": "allow",
      "git tag": "allow",
      "git tag -l *": "allow",
      "git remote -v": "allow",
      "git remote": "allow",
      "git stash list": "allow",
      "git reflog": "allow",
      "git shortlog *": "allow",
      "git ls-files": "allow",
      "git ls-files *": "allow",
      "gh auth status": "allow",
      "gh repo view": "allow",
      "gh repo view *": "allow",
      "gh issue list": "allow",
      "gh issue view *": "allow",
      "gh pr list": "allow",
      "gh pr view *": "allow",
      "gh pr checks *": "allow",
      "gh run list": "allow",
      "gh run view *": "allow",
      "gh release list": "allow",
      "gh release view *": "allow",
      "gh api *": "allow",
      "gh gist list": "allow",
      "gh gist view *": "allow",
      "* .env.example": "allow",
      "* .env": "deny",
      "* .env.*": "deny",
      "* ./.env": "deny",
      "* ./.env.*": "deny"
    },
    "read": {
      "*": "allow",
      "*.env.example": "allow",
      "*.env": "deny",
      "*.env.*": "deny"
    }
  },

  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "excel": {
      "type": "local",
      "command": ["uvx", "excel-mcp-server", "stdio"],
      "enabled": false
    },
    "jupyter": {
      "type": "local",
      "command": ["uvx", "mcp-jupyter-notebook"],
      "enabled": false,
      "env": {
        "MCP_JUPYTER_SESSION_MODE": "server",
        "MCP_JUPYTER_BASE_URL": "http://localhost:8888",
        "MCP_JUPYTER_TOKEN": "mcp-dev-token",
        "MCP_JUPYTER_NOTEBOOK_PATH": "agent_demo.ipynb"
      }
    }
  }
}
