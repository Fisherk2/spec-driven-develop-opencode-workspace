{
  "$schema": "https://opencode.ai/config.json",

  "model": "opencode/deepseek-v4-flash-free",
  "small_model": "openrouter/z-ai/glm-4.5-air:free",

  "agent": {
    "build": {
      "model": "opencode/nemotron-3-super-free"
    },
    "plan": {
      "model": "opencode/big-pickle"
    },
    "explore": {
      "model": "openrouter/meta-llama/llama-4-scout:free"
    }
  },

  "instructions": [
    "CONTRIBUTING.md",
    "USER_GUIDE.md",
    "docs/opencode/08-orchestration-patterns.md"
  ],

  "permission": {
    "bash": {
      "*": "ask",
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "grep *": "allow"
    },
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    }
  },

  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    }
  }
}
